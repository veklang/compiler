{
  "name": "veklang",
  "main": "./src/index.ts",
  "bin": {
    "vekc": "./build/index.js"
  },
  "type": "commonjs",
  "scripts": {
    "build": "cd src && swc . -d ../build --config-file ../.swcrc && cd ..",
    "bundle": "cd src && swc . -d ../build --config-file ../.swcrc && cd .. && esbuild build/index.js --bundle --platform=node --format=cjs --minify --outfile=dist/bundle.js",
    "format": "biome format --write src tests",
    "lint": "biome lint --write src tests",
    "test": "tsx tests/run.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.24",
    "@swc/helpers": "^0.5.21",
    "@types/node": "^25.5.2",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0"
  }
}
