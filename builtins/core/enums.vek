pub enum Ordering {
  Less;
  Equal;
  Greater;
}

pub enum Result<T, E> {
  Ok(T);
  Err(E);

  satisfies Unwrappable<T> {
    fn unwrap(self) -> T {
      match self {
        Ok(value) => { return value; }
        Err(_) => { panic("called unwrap on an Err value"); }
      }
    }

    fn unwrap_or(self, default: T) -> T {
      return match self {
        Ok(value) => value,
        Err(_) => default,
      };
    }
  }
}
